{
  "autoDreamEnabled": true,
  "permissions": {
    "allow": [
      "Bash",
      "mcp__claude_ai_ms365__outlook_email_search",
      "mcp__claude_ai_ms365__outlook_calendar_search",
      "mcp__claude_ai_Slack__slack_search_public",
